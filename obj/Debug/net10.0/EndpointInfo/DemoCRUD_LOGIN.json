        ],
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "Name": {
                    "type": "string"
                  },
                  "Price": {
                    "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
